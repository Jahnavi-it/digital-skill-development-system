# Copy this file to .env and fill in your real values. Never commit the real .env file.

# MySQL connection
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dsds_db

# Flask / JWT
SECRET_KEY=change-this-to-a-long-random-string
JWT_SECRET_KEY=change-this-to-a-different-long-random-string
